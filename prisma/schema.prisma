generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  type        String
  category    String
  description String
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Budget {
  category    String   @id
  limit       Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
