# Supabase Database (PostgreSQL)
# Use the "Transaction" connection string (usually port 6543) for DATABASE_URL
DATABASE_URL="postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:6543/postgres?pgbouncer=true"
# Use the "Session" or "Direct" connection string (usually port 5432) for DIRECT_URL
DIRECT_URL="postgres://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase Client Keys (Found under Settings -> API)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"
